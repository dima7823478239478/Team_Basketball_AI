# ===========================
# Python / Авто-генерируемые файлы
# ===========================
__pycache__/
*.py[cod]
*.so
.Python
*.egg-info/
dist/
build/
*.egg

# ===========================
# Виртуальные окружения
# ===========================
venv/
env/
ENV/
.venv

# ===========================
# Jupyter Notebooks (кэш и проверки)
# ===========================
.ipynb_checkpoints/
*.ipynb_checkpoints
.checkpoints/

# ===========================
# Данные (ОЧЕНЬ ВАЖНО!)
# ===========================
# Сырые данные — скорее всего большие, не для Git
*.csv
*.xlsx
*.parquet
*.h5
*.feather

# Базы данных
*.db
*.sqlite
*.sqlite3

# Но можно исключить маленькие примеры или сэмплы (раскомментируй если нужно)
# !sample_*.csv
# !example_*.csv

# ===========================
# Модели и векторайзеры (обычно тяжелые)
# ===========================
*.pkl
*.joblib
*.hdf5
*.onnx
*.pt
*.pth

# ===========================
# Изображения / графики (если генерируются автоматически)
# ===========================
*.png
*.jpg
*.jpeg
*.gif
*.svg
# !plots/*.png   # если хочешь сохранять графики, раскомментировать

# ===========================
# Логи и временные файлы
# ===========================
*.log
*.tmp
temp/
tmp/
logs/

# ===========================
# IDE / Редакторы
# ===========================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
desktop.ini

# ===========================
# Переменные окружения / секреты
# ===========================
.env
.venv
secrets.py
config_local.py

# ===========================
# Результаты экспериментов / отчеты (если генерируются)
# ===========================
experiments/
results/
output/
*.html

# ===========================
# Git
# ===========================
*.orig
*.rej